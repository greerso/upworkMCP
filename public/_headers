/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  # CSP for assets. style-src 'unsafe-inline' matches appendSecurityHeaders() in src/index.ts
  # and public/index.html's inline body style attribute.
  Content-Security-Policy: default-src 'self'; frame-ancestors 'none'; style-src 'unsafe-inline';
